{
  "name": "fifoflow",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "fifoflow",
      "workspaces": [
        "packages/shared",
        "packages/server",
        "packages/client"
      ]
    },
    "node_modules/@fifoflow/client": {
      "resolved": "packages/client",
      "link": true
    },
    "node_modules/@fifoflow/server": {
      "resolved": "packages/server",
      "link": true
    },
    "node_modules/@fifoflow/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/client": {
      "name": "@fifoflow/client",
      "version": "0.0.1",
      "dependencies": {
        "@fifoflow/shared": "*"
      }
    },
    "packages/server": {
      "name": "@fifoflow/server",
      "version": "0.0.1",
      "dependencies": {
        "@fifoflow/shared": "*"
      }
    },
    "packages/shared": {
      "name": "@fifoflow/shared",
      "version": "0.0.1"
    }
  }
}
